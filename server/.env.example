# Copy this file to .env and adjust values for your environment.

PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Used to sign login sessions (JWT). Use a long, random string in production.
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# First-run bootstrap admin account. Created only if the users table is empty.
# Change the password after your first login.
BOOTSTRAP_ADMIN_NAME=Site Admin
BOOTSTRAP_ADMIN_EMAIL=admin@swiftchauffeurs.com
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
